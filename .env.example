# Azure AD / Microsoft 365 SSO Configuration
# Copy this file to .env and fill in your values from the Azure portal

# Azure AD Tenant ID (found in Azure Portal > Azure Active Directory > Overview)
AZURE_TENANT_ID=your-tenant-id-here

# Application (client) ID (found in Azure Portal > App registrations > your app > Overview)
AZURE_CLIENT_ID=your-client-id-here

# Client secret value (created in Azure Portal > App registrations > your app > Certificates & secrets)
AZURE_CLIENT_SECRET=your-client-secret-here

# The full URL where Azure AD will redirect after login (must match exactly in Azure portal)
# For local dev: http://localhost:3001/auth/callback
# For production: https://yourdomain.com/auth/callback
REDIRECT_URI=http://localhost:3001/auth/callback

# The URL to redirect to after logout (must be registered in Azure portal)
POST_LOGOUT_REDIRECT_URI=http://localhost:3001

# Secret used to sign the session cookie — use a long random string in production
SESSION_SECRET=change-this-to-a-long-random-secret

BASE_PATH=/kpi

# Server port
PORT=4001

# Set to true to bypass SSO on developer machines (never use in production)
# DEV_MODE=true
